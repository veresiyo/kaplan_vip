rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // 🚀 DEVELOPMENT MODE (İlk Kurulum İçin)
    // ============================================
    // Bütün okuma/yazma işlemlerine izin ver
    // ⚠️ UYARI: Production'a geçerken bu rules değiştirilmeli!
    
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 6, 1);
    }

    // ============================================
    // 📋 COLLECTION: drivers (Şoförler)
    // ============================================
    // Bütünü okuyabilen herkes görebilsin ama yazma yetki gerekli
    match /drivers/{driverId} {
      // Okuma: Authenticated users
      allow read: if request.auth != null;
      
      // Yazma: Admin ve kendisi
      allow create, update: if 
        request.auth != null && 
        (isAdmin(request.auth.uid) || request.auth.uid == driverId);
      
      // Silme: Admin sadece
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
      
      // Şoför kendi belgesini okuyabilir
      allow read: if request.auth.uid == driverId;
    }

    // ============================================
    // 🚗 COLLECTION: vehicles_collection (Araçlar)
    // ============================================
    match /vehicles_collection/{vehicleId} {
      // Okuma: Authenticated users
      allow read: if request.auth != null;
      
      // Yazma: Admin ve Python scripti (service account)
      allow create, update: if 
        request.auth != null && 
        isAdmin(request.auth.uid);
      
      // Silme: Admin sadece
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ============================================
    // 📋 COLLECTION: transfers (Transfer İşleri)
    // ============================================
    match /transfers/{transferId} {
      // Okuma: Authenticated users
      allow read: if request.auth != null;
      
      // Yazma: Admin
      allow create, update: if 
        request.auth != null && 
        isAdmin(request.auth.uid);
      
      // Silme: Admin sadece
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
      
      // Şoför kendi transferlerini okuyabilir (driverId eşitse)
      allow read: if 
        request.auth != null && 
        request.auth.uid == get(/databases/$(database)/documents/drivers/$(resource.data.driver_id)).data.user_id;
    }

    // ============================================
    // 🔧 COLLECTION: maintenance_logs (Bakım Kayıtları)
    // ============================================
    match /maintenance_logs/{logId} {
      // Okuma: Maintenance department ve Admin
      allow read: if 
        request.auth != null && 
        (isAdmin(request.auth.uid) || isMaintenance(request.auth.uid));
      
      // Yazma: Maintenance department ve Admin
      allow create, update: if 
        request.auth != null && 
        (isAdmin(request.auth.uid) || isMaintenance(request.auth.uid));
      
      // Silme: Admin sadece
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ============================================
    // 👥 COLLECTION: users (Kullanıcı Bilgileri)
    // ============================================
    match /users/{userId} {
      // Kendi profilinizi okuyabilirsiniz
      allow read: if request.auth.uid == userId;
      
      // Kendi profilinizi güncelleyebilirsiniz
      allow update: if request.auth.uid == userId;
      
      // Admin tarafından oluşturulur
      allow create: if request.auth != null && isAdmin(request.auth.uid);
      
      // Admin silebilir
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ============================================
    // ⚙️ HELPER FUNCTIONS
    // ============================================
    
    /// Admin kontrolü (Firestore'da users/{uid} altında role='admin')
    function isAdmin(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
    }
    
    /// Maintenance department kontrolü
    function isMaintenance(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'maintenance';
    }
    
    /// Driver kontrolü
    function isDriver(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'driver';
    }
  }
}
